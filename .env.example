# API
ALPHAVANTAGE_API_KEY=Y3YOW5NU1R7P9QIL
ALPHAVANTAGE_SYMBOL=IBM
ALPHAVANTAGE_INTERVAL=1min

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=market_ticks
KAFKA_CLIENT_ID=alpha-producer

# Pipeline
STREAM_WINDOW_SECONDS=30
STREAM_SLIDE_SECONDS=30
SPARK_MASTER=local[*]
# Si usas Spark local compilado con scala distinta, ajústalo aquí.
# En tu máquina actual (Spark 3.5.4 + scala 2.13), este valor queda:
# SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.13:3.5.4
# También puedes configurar por separado:
# SPARK_KAFKA_VERSION=3.5.4
# SPARK_SCALA_BINARY_VERSION=2.13
OUTPUT_DIR=output
CHECKPOINT_DIR=output/checkpoints

# Producer control
PRODUCER_RATE_PER_SECOND=30
